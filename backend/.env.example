# ========================================
# DocuAgent Environment Configuration
# ========================================

# 1. Server Configuration
PROJECT_NAME="DocuAgent"
SECRET_KEY="replace-this-with-a-very-long-strong-secret"
ALGORITHM="HS256"

# 2. LiteLLM Multi-Provider Configurations
# LiteLLM supports 100+ providers. Set the active model below.
LITELLM_DEFAULT_MODEL="gemini/gemini-pro"
# Alternatively, try these:
# LITELLM_DEFAULT_MODEL="gpt-4o"
# LITELLM_DEFAULT_MODEL="claude-3-opus-20240229"
# LITELLM_DEFAULT_MODEL="ollama/llama3" # for local models

# Provider API Keys
# Gemini
GEMINI_API_KEY="your_gemini_api_key_here"

# OpenAI
OPENAI_API_KEY="your_openai_api_key_here"

# Anthropic
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Groq
GROQ_API_KEY="your_groq_api_key_here"

# 3. Database
SQLALCHEMY_DATABASE_URI="sqlite:///./docuagent.db"
